    "@starknetfoundation/starknet-start-chains": "workspace:^",
    "abi-wan-kanabi": "^2.2.4",
    "viem": "^2.21.1"
  },
  "devDependencies": {
    "@starknetfoundation/starknet-start-typescript-config": "workspace:^",
    "rimraf": "^4.1.2",
    "tsdown": "^0.16.8",
    "vitest": "^4.0.15"
  },
  "peerDependencies": {
    "starknet": ">=10.4.0"
  }
}
