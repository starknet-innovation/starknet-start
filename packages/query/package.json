{
  "name": "@starknetfoundation/starknet-start-query",
  "version": "1.0.7",
  "keywords": [
    "ethereum",
    "l2",
    "starknet"
  ],
  "homepage": "https://starknet-innovation.github.io/starknet-start/",
  "license": "MIT",
  "repository": "starknet-innovation/starknet-start",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
