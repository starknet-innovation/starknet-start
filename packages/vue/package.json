{
  "name": "@starknetfoundation/starknet-start-vue",
  "version": "0.0.1-alpha.2",
  "keywords": [
    "ethereum",
    "l2",
    "starknet",
    "vue"
  ],
  "homepage": "https://github.com/starknet-innovation/starknet-start#readme",
  "license": "MIT",
  "repository": "starknet-innovation/starknet-start",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.mts",
      "import": "./dist/hooks/index.mjs",
      "default": "./dist/hooks/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "@starknet-io/get-starknet-wallet-standard": "^5.0.0",
    "@starknet-io/types-js": "^0.10.1",
    "@starknetfoundation/starknet-start-chains": "workspace:^",
    "@starknetfoundation/starknet-start-explorers": "workspace:^",
    "@starknetfoundation/starknet-start-providers": "workspace:^",
    "@starknetfoundation/starknet-start-query": "workspace:^",
    "@tanstack/vue-query": "^5.25.0"
  },
  "devDependencies": {
    "@starknetfoundation/starknet-start-typescript-config": "workspace:^",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^27.2.0",
    "rimraf": "^4.1.2",
    "starknet": "^9.4.2",
    "tsdown": "^0.16.8",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.15",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "starknet": "^9.4.2",
    "vue": "^3.4.0"
  }
}
