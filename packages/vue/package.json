{
  "name": "@starknet-start/vue",
  "version": "0.0.1-alpha.2",
  "private": true,
  "homepage": "https://github.com/starknet-innovation/starknet-start#readme",
  "license": "MIT",
  "repository": "starknet-innovation/starknet-start",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.mts",
      "import": "./dist/hooks/index.mjs",
      "default": "./dist/hooks/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@starknet-io/get-starknet-wallet-standard": "^6.0.2",
    "@starknet-io/types-js": "^0.10.3",
    "@starknet-start/chains": "workspace:^",
    "@starknet-start/explorers": "workspace:^",
    "@starknet-start/providers": "workspace:^",
    "@starknet-start/query": "workspace:^",
    "@tanstack/vue-query": "^5.25.0"
  },
  "devDependencies": {
    "@starknet-start/typescript-config": "workspace:^",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^27.2.0",
    "rimraf": "^4.1.2",
    "starknet": "^10.4.0",
    "tsdown": "^0.16.8",
    "vitest": "^4.0.15",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "starknet": ">=10.4.0",
    "vue": "^3.4.0"
  }
}
