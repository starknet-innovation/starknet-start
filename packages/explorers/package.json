{
  "name": "@starknetfoundation/starknet-start-explorers",
  "version": "1.0.7",
  "keywords": [
    "ethereum",
    "l2",
    "starknet"
  ],
  "homepage": "https://starknet-innovation.github.io/starknet-start/",
  "license": "MIT",
  "repository": "starknet-innovation/starknet-start",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "@starknetfoundation/starknet-start-chains": "workspace:^"
  },
  "devDependencies": {
    "@starknetfoundation/starknet-start-typescript-config": "workspace:^",
    "rimraf": "^4.1.2",
    "tsdown": "^0.16.8",
    "vitest": "^4.0.15"
  }
}
