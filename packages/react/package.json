    "@vitejs/plugin-react": "^5.1.1",
    "@wallet-standard/features": "^1.1.0",
    "jsdom": "^27.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^4.1.2",
    "starknet": "^10.4.0",
    "tsdown": "^0.16.8",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.15"
  },
  "peerDependencies": {
    "@starknet-io/get-starknet-core": ">=6.0.0",
    "@starknet-io/get-starknet-modal": ">=6.0.0",
    "@starknet-io/get-starknet-wallet-standard": ">=6.0.0",
    "react": ">=19.0.0",
    "starknet": ">=10.4.0"
