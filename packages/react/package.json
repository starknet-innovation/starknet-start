{
  "name": "@starknet-start/react",
  "version": "1.0.8",
  "keywords": [
    "ethereum",
    "l2",
    "starknet"
  ],
  "homepage": "https://github.com/starknet-innovation/starknet-start#readme",
  "license": "MIT",
  "repository": "starknet-innovation/starknet-start",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
