  },
  "dependencies": {
    "@starknet-io/types-js": "^0.10.3",
    "@starknet-start/chains": "workspace:^",
    "@starknet-start/explorers": "workspace:^",
    "@starknet-start/providers": "workspace:^",
    "@starknet-start/query": "workspace:^",
    "@tanstack/react-query": "^5.25.0",
    "abi-wan-kanabi": "^2.2.4",
    "eventemitter3": "^5.0.1",
    "lossless-json": "^4.3.0",
    "viem": "^2.21.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@starknet-io/get-starknet-core": "^6.0.1",
    "@starknet-io/get-starknet-modal": "^6.0.1",
