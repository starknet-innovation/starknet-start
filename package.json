{
  "name": "starknet-start",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/starknet-start/starknet-start.git"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test --parallel",
    "test:ci": "turbo run test:ci --parallel",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "clean": "turbo run clean --parallel",
    "typecheck": "turbo run typecheck --parallel"
  },
  "devDependencies": {
    "beachball": "^2.55.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.18.0",
  "beachball": {
    "ignorePatterns": [
      "docs/**",
      "packages/vue/**"
    ]
  }
}